# ==============================================================================
# Digital Freeman - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ==============================================================================
# LLM API KEYS
# ==============================================================================
# Anthropic Claude API (primary LLM for Freeman)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OpenAI API (for embeddings, image generation, and optional LLM)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenRouter API (alternative LLM routing)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google API (Gemini)
GOOGLE_API_KEY=your-google-api-key-here

# Model selection
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ==============================================================================
# GRAPHITI MEMORY SYSTEM
# ==============================================================================
# Graphiti MCP server configuration
GRAPHITI_MCP_SERVER_URL=http://localhost:8080
GRAPHITI_MCP_TIMEOUT=30

# Graphiti database configuration
GRAPHITI_DB_HOST=localhost
GRAPHITI_DB_PORT=7687
GRAPHITI_DB_USER=neo4j
GRAPHITI_DB_PASSWORD=your_neo4j_password
GRAPHITI_DB_NAME=graphiti

# Memory storage path (local file-based storage)
GRAPHITI_DATA_PATH=./data/memory

# Memory configuration
GRAPHITI_MAX_ENTITIES=10000
GRAPHITI_MAX_EPISODES=50000
GRAPHITI_SEARCH_LIMIT=10
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# ==============================================================================
# MEMORY SYSTEM SETTINGS
# ==============================================================================
# Relationship scoring thresholds
RELATIONSHIP_STRANGER_THRESHOLD=0
RELATIONSHIP_ACQUAINTANCE_THRESHOLD=10
RELATIONSHIP_FRIEND_THRESHOLD=50
RELATIONSHIP_ALLY_THRESHOLD=200

# Action scoring
ACTION_LIKE_POINTS=1
ACTION_SHARE_POINTS=3
ACTION_COMMENT_POINTS=5
ACTION_PURCHASE_TOKEN_POINTS=50

# Memory retention
MEMORY_RETENTION_DAYS=365
MEMORY_CLEANUP_ENABLED=false

# ==============================================================================
# PLATFORM INTEGRATIONS - TELEGRAM
# ==============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ==============================================================================
# PLATFORM INTEGRATIONS - DISCORD
# ==============================================================================
# Discord Bot Token (get from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Optional: Guild ID for guild-specific operations
# DISCORD_GUILD_ID=123456789012345678
# Command prefix for text commands (default: "!")
# DISCORD_COMMAND_PREFIX=!
# Optional: Comma-separated list of allowed guild IDs (empty = all guilds allowed)
# DISCORD_ALLOWED_GUILDS=123456789012345678,876543210987654321

# ==============================================================================
# PLATFORM INTEGRATIONS - TWITTER/X
# ==============================================================================
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ==============================================================================
# PLATFORM EXTENSION FRAMEWORK CONFIGURATION
# ==============================================================================
# Comma-separated list of platforms to enable for the Platform Extension Framework.
# This controls the new platform abstraction layer (src/platforms).
# Set to "none" to disable all platforms (default).
# Empty value or "all" enables all configured platforms with valid tokens.
# Example: ENABLED_PLATFORMS=telegram,discord
ENABLED_PLATFORMS=none

# ==============================================================================
# DATABASE
# ==============================================================================
# Primary database for application data
DATABASE_URL=postgresql://user:password@localhost:5432/freeman_db

# Vector Database (for memory embeddings)
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=your_vector_db_api_key_here

# Redis for caching and session management
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# SENTIENT FRAMEWORK
# ==============================================================================
# Sentient Agent Framework configuration (if required)
SENTIENT_API_KEY=your_sentient_api_key
SENTIENT_AGENT_ID=freeman
SENTIENT_WORKSPACE_ID=your_workspace_id

# ==============================================================================
# IMAGE GENERATION
# ==============================================================================
# Stability AI (alternative to DALL-E)
STABILITY_API_KEY=your_stability_api_key_here

# Midjourney (if integrated)
MIDJOURNEY_API_KEY=your_midjourney_api_key_here

# ==============================================================================
# CONTENT CREATION PIPELINE
# ==============================================================================
# Content generation interval (seconds between content generation)
CONTENT_GENERATION_INTERVAL=3600
# Minimum seconds between posts
MIN_POST_INTERVAL=7200
# Maximum similarity with past content (0-1)
MAX_SIMILARITY_THRESHOLD=0.85

# ==============================================================================
# FREEMAN PERSONA SETTINGS
# ==============================================================================
# Voice level: 1-10, how provocative/sarcastic
PERSONA_VOICE_LEVEL=8
# Enable Freeman's characteristic language
ENABLE_PROFANITY=true

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
# Environment mode
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/freeman.log

# Server configuration
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-secret-key-for-session-encryption
ALLOWED_HOSTS=localhost,127.0.0.1

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ==============================================================================
# PERSONA CONFIGURATION
# ==============================================================================
# Active personas (comma-separated IDs)
ACTIVE_PERSONAS=freeman

# Default persona for API requests
DEFAULT_PERSONA=freeman

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable multi-persona support
MULTI_PERSONA_ENABLED=true

# Enable self-reflection agent (post-MVP)
SELF_REFLECTION_ENABLED=false

# Enable content generation
CONTENT_GENERATION_ENABLED=true

# Enable memory persistence
MEMORY_PERSISTENCE_ENABLED=true

# ==============================================================================
# MONITORING & ANALYTICS
# ==============================================================================
# Application monitoring (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=

# ==============================================================================
# WEBHOOKS & INTEGRATIONS (Optional)
# ==============================================================================
# Webhook URL for external notifications
WEBHOOK_URL=https://your-webhook-url.com/webhook

# Discord webhook (for team notifications)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
